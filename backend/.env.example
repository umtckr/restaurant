DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
REDIS_URL=redis://127.0.0.1:6379/0

# --- PostgreSQL (required in production) ---
# POSTGRES_DB=dinebird
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- Cloudinary (required in production for media uploads) ---
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# --- Resend (required in production for transactional email) ---
# RESEND_API_KEY=re_your_api_key
# DEFAULT_FROM_EMAIL=Dinebird <noreply@dinebird.com>
