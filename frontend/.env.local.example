# Copy to .env.local for overrides. `.env.local` overrides `.env.development`.

# Optional — production API or custom dev URL. Defaults are set in:
# - `.env.development` (npm run dev)
# - `src/lib/api/client.ts` (development → http://127.0.0.1:8000/api/v1 when unset)
#
# Do NOT point at the Next dev server or you get redirect loops, e.g. avoid:
# NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# NEXT_PUBLIC_API_URL=https://api.example.com/api/v1

# Django URL for Next rewrites (only if you use same-origin /api/v1 without NEXT_PUBLIC_API_URL).
# API_PROXY_TARGET=http://127.0.0.1:8000

NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000
